// Runnable counter: pure transform + local state + Level-2 hold.

schema Tick {
  value: Int
}

transform add(x: Int) -> Int {
  x + 1
}

process Counter {
  state total: Int = 0

  on tick: Tick {
    let next = total + tick.value
    let bumped = next ~> add
    total := bumped
  }
}

spec CounterSafe {
  hold total >= 0
}
