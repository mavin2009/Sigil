// Counter with a pure compiled transform body (not residual).

schema Tick {
  value: Int
}

schema Count {
  total: Int
}

transform add(x: Int) -> Int {
  x + 1
}

process Counter {
  state total: Int = 0

  on tick: Tick {
    let next = total + tick.value
    let bumped = next ~> add
    total := bumped
  }
}
